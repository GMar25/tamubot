<node id="Interpret And Evaluate Legal Frameworks">
  <data key="d0">Interpret And Evaluate Legal Frameworks</data>
  <data key="d1">learningoutcome</data>
  <data key="d2">Students will learn to interpret and evaluate key legal frameworks related to disability and accessibility, and assess their implications for technology development.</data>
  <data key="d3">chunk-88f4d8e2b60cb901518686edff30fd85</data>
