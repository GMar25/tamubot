  <data key="d0">Quizzes Grade Component</data>
  <data key="d1">gradecomponent</data>
  <data key="d2">Quizzes comprise 20% of the final grade, consisting of four brief in-class quizzes (5%+5%+5%+5%).</data>
  <data key="d3">chunk-4375e28268d2a8a30d4105aa2942d3a6</data>
  <data key="d4">unknown_source</data>
