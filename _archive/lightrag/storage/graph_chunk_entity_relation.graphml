  <data key="d0">CSCE 632 Syllabus</data>
  <data key="d1">content</data>
  <data key="d2">The CSCE 632 Syllabus is a document outlining the course information, instructor details, catalog description, prerequisites, and learning outcomes for the Accessible Computing course.</data>
  <data key="d3">chunk-ba4efe7cbbae89248097dee77152dc54</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1774689639</data>
