</node>
<node id="CSCE 632">
  <data key="d0">CSCE 632</data>
  <data key="d1">concept</data>
  <data key="d2">CSCE 632 is a graduate-level course (Section 600, course number 54784) titled "Accessible Computing," offered in Spring 2026 with 3 credit hours.&lt;SEP&gt;CSCE 632 is a course designation where Pre-Class Engagement accounts for 5% of the grade.&lt;SEP&gt;A specific course for which the Literature Review is 10% of the grade and the Current Research Presentation is 5%.</data>
  <data key="d3">chunk-ba4efe7cbbae89248097dee77152dc54&lt;SEP&gt;chunk-686108f24ad2964e2eb6746fc5d77479&lt;SEP&gt;chunk-e5894fe93e51bdc7af7bed3d548cd3ac</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1774689708</data>
  <data key="d6"></data>
</node>
<node id="Accessible Computing">
  <data key="d0">Accessible Computing</data>
  <data key="d1">concept</data>
  <data key="d2">Accessible Computing is the title of the CSCE 632 course, focusing on disenfranchised user populations due to</data>
  <data key="d3">chunk-ba4efe7cbbae89248097dee77152dc54</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1774689639</data>
  <data key="d6"></data>
</node>
<node id="Disability Models">
  <data key="d0">Disability Models</data>
  <data key="d1">concept</data>
  <data key="d2">Disability Models are different frameworks used to understand disability, including the civil rights model.</data>
  <data key="d3">chunk-686108f24ad2964e2eb6746fc5d77479</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1774689672</data>
  <data key="d6"></data>
</node>
<node id="Civil Rights Model">
  <data key="d0">Civil Rights Model</data>
  <data key="d1">concept</data>
  <data key="d2">The Civil Rights Model is a specific model of disability discussed in relation to accessibility.</data>
  <data key="d3">chunk-686108f24ad2964e2eb6746fc5d77479</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1774689672</data>
  <data key="d6"></data>
</node>
<node id="Accessibility">
  <data key="d0">Accessibility</data>
  <data key="d1">concept</data>
  <data key="d2">Accessibility refers to the quality of being usable by all people, regardless of ability, and is impacted by models of disability and supported by strategies.</data>
  <data key="d3">chunk-686108f24ad2964e2eb6746fc5d77479</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1774689672</data>
  <data key="d6"></data>
</node>
<node id="Accessibility Standards">
  <data key="d0">Accessibility Standards</data>
  <data key="d1">concept</data>
  <data key="d2">Accessibility Standards are established criteria used in the design and implementation of technology solutions to ensure usability for diverse users.&lt;SEP&gt;Standards like WCAG and ARIA, covered in Week 5.</data>
  <data key="d3">chunk-686108f24ad2964e2eb6746fc5d77479&lt;SEP&gt;chunk-e8e37fa109ec92fd9441dfefb914b096</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1774689810</data>
  <data key="d6"></data>
</node>
<node id="Technology Solutions">
  <data key="d0">Technology Solutions</data>
  <data key="d1">concept</data>
  <data key="d2">Technology Solutions are approaches and designs for implementing technology, which should apply relevant accessibility standards.</data>
  <data key="d3">chunk-686108f24ad2964e2eb6746fc5d77479</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1774689672</data>
  <data key="d6"></data>
</node>
<node id="Facilitators">
  <data key="d0">Facilitators</data>
  <data key="d1">concept</data>
  <data key="d2">Facilitators are elements or factors that promote or ease technology use.</data>
  <data key="d3">chunk-686108f24ad2964e2eb6746fc5d77479</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1774689672</data>
  <data key="d6"></data>
</node>
<node id="Barriers To Technology Use">
  <data key="d0">Barriers To Technology Use</data>
  <data key="d1">concept</data>
  <data key="d2">Barriers To Technology Use are obstacles that hinder people's ability to use technology.</data>
  <data key="d3">chunk-686108f24ad2964e2eb6746fc5d77479</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1774689672</data>
  <data key="d6"></data>
</node>
<node id="Strategies">
  <data key="d0">Strategies</data>
  <data key="d1">concept</data>
  <data key="d2">Strategies are plans or methods designed to reduce barriers and support accessibility for diverse users.</data>
  <data key="d3">chunk-686108f24ad2964e2eb6746fc5d77479</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1774689672</data>
  <data key="d6"></data>
</node>
<node id="Diverse Users">
  <data key="d0">Diverse Users</data>
  <data key="d1">concept</data>
  <data key="d2">Diverse Users refer to a broad range of individuals, including people with disabilities, for whom accessibility should be supported.</data>
  <data key="d3">chunk-686108f24ad2964e2eb6746fc5d77479</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1774689672</data>
  <data key="d6"></data>
</node>
<node id="Accessible Technologies">
  <data key="d0">Accessible Technologies</data>
  <data key="d1">concept</data>
  <data key="d2">Accessible Technologies are technologies developed to comply with established standards and whose effectiveness is evaluated for people with disabilities and other populations.</data>
  <data key="d3">chunk-686108f24ad2964e2eb6746fc5d77479</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1774689672</data>
  <data key="d6"></data>
</node>
<node id="Documents">
  <data key="d0">Documents</data>
  <data key="d1">content</data>
  <data key="d2">Documents are materials that can be developed to be accessible and comply with established standards.</data>
  <data key="d3">chunk-686108f24ad2964e2eb6746fc5d77479</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1774689672</data>
  <data key="d6"></data>
</node>
<node id="Presentations">
  <data key="d0">Presentations</data>
  <data key="d1">content</data>
  <data key="d2">Presentations are informational displays that can be developed to be accessible and comply with established standards.</data>
  <data key="d3">chunk-686108f24ad2964e2eb6746fc5d77479</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1774689672</data>
  <data key="d6"></data>
</node>
<node id="Universal Design Principles">
  <data key="d0">Universal Design Principles</data>
  <data key="d1">concept</data>
  <data key="d2">Universal Design Principles are a framework used to justify design choices for equitable interaction.</data>
  <data key="d3">chunk-686108f24ad2964e2eb6746fc5d77479</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1774689672</data>
  <data key="d6"></data>
</node>
<node id="Equitable Interaction">
  <data key="d0">Equitable Interaction</data>
  <data key="d1">concept</data>
  <data key="d2">Equitable Interaction refers to fair and impartial engagement facilitated by solutions mediating challenges and barriers for specific disabilities.</data>
  <data key="d3">chunk-686108f24ad2964e2eb6746fc5d77479</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1774689672</data>
  <data key="d6"></data>
</node>
<node id="Technology">
  <data key="d0">Technology</data>
  <data key="d1">concept</data>
  <data key="d2">Technology refers to tools and systems that can be critiqued for their adherence to accessibility standards.</data>
  <data key="d3">chunk-686108f24ad2964e2eb6746fc5d77479</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1774689672</data>
  <data key="d6"></data>
</node>
<node id="Design Alternatives">
  <data key="d0">Design Alternatives</data>
  <data key="d1">concept</data>
  <data key="d2">Design Alternatives are different proposals for fulfilling the underlying goals of accessibility when existing standards may be insufficient.</data>
  <data key="d3">chunk-686108f24ad2964e2eb6746fc5d77479</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1774689672</data>
  <data key="d6"></data>
</node>
