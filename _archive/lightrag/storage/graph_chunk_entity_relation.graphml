  <data key="d1">concept</data>
  <data key="d2">Online or in-class assignments consisting of a few simple questions, contributing 10% to the final grade.</data>
  <data key="d3">chunk-bfd68ceb87515331e129a9abd37822bd</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1774689607</data>
  <data key="d6"></data>
</node>
<node id="Final Grades">
  <data key="d0">Final Grades</data>
  <data key="d1">concept</data>
  <data key="d2">The overall grade assigned based on a defined scale (A, B, C, D, F) and potentially a curve.</data>
  <data key="d3">chunk-bfd68ceb87515331e129a9abd37822bd</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1774689607</data>
  <data key="d6"></data>
</node>
<node id="Curve">
  <data key="d0">Curve</data>
