  <data key="d1">academicpolicy</data>
  <data key="d2">The Course Grading Policy defines the percentage ranges for letter grades A, B, C, D, and F.</data>
  <data key="d3">chunk-843558fd9ea1f2553bd06e6050b8334b</data>
  <data key="d4">unknown_source</data>
