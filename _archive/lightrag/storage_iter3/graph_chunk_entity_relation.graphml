  <data key="d0">Yu Zhang</data>
  <data key="d1">instructor</data>
  <data key="d2">Yu Zhang is the instructor for CSCE 670, with an email yuzhang@tamu.edu, office at PETR 222, and office hours on Mondays 3:30 – 4:30 PM.</data>
  <data key="d3">chunk-97b761a3d4ccc38fabdc762f72330b3b</data>
