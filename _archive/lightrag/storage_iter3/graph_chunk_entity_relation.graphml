  <data key="d0">Retrieval</data>
  <data key="d1">textbook</data>
  <data key="d2">Retrieval is a textbook written by Christopher D. Manning, Prabhakar Raghavan, and Hinrich Schutze, published in 2009, and available online at https://nlp.stanford.edu/IR-book/.</data>
  <data key="d3">chunk-843558fd9ea1f2553bd06e6050b8334b</data>
