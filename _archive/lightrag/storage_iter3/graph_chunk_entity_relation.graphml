  <data key="d1">gradecomponent</data>
  <data key="d2">Quizzes contribute 20% to the overall course grade and consist of four brief in-class quizzes.</data>
  <data key="d3">chunk-843558fd9ea1f2553bd06e6050b8334b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1774749493</data>
  <data key="d6"></data>
</node>
<node id="Final">
  <data key="d0">Final</data>
  <data key="d1">gradecomponent</data>
  <data key="d2">The Final exam contributes 30% to the overall course grade and is a comprehensive final exam.</data>
  <data key="d3">chunk-843558fd9ea1f2553bd06e6050b8334b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1774749493</data>
  <data key="d6"></data>
</node>
<node id="Group Project">
  <data key="d0">Group Project</data>
  <data key="d1">gradecomponent</data>
  <data key="d2">The Group Project contributes 20% to the overall course grade and involves students working in teams on a mini-research project.</data>
  <data key="d3">chunk-843558fd9ea1f2553bd06e6050b8334b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1774749493</data>
  <data key="d6"></data>
</node>
<node id="Course Homework Assignments">
  <data key="d0">Course Homework Assignments</data>
  <data key="d1">assignment</data>
  <data key="d2">There will be five programming assignments, all in Python, with specific weights (2%, 7%, 7%, 7%, 7%). The first assignment is introductory, focusing on Jupyter Notebook and Python operations.</data>
  <data key="d3">chunk-843558fd9ea1f2553bd06e6050b8334b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1774749493</data>
  <data key="d6"></data>
</node>
<node id="Course Quizzes">
  <data key="d0">Course Quizzes</data>
  <data key="d1">assignment</data>
  <data key="d2">There will be four brief in-class quizzes, each contributing 5% to the grade.</data>
  <data key="d3">chunk-843558fd9ea1f2553bd06e6050b8334b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1774749493</data>
  <data key="d6"></data>
</node>
<node id="Course Final Exam">
  <data key="d0">Course Final Exam</data>
  <data key="d1">exam</data>
  <data key="d2">A comprehensive final exam will be held on May 4 from 3:30 PM - 5:30 PM in HRBB 113.</data>
  <data key="d3">chunk-843558fd9ea1f2553bd06e6050b8334b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1774749493</data>
  <data key="d6"></data>
</node>
<node id="Course Group Project">
  <data key="d0">Course Group Project</data>
  <data key="d1">assignment</data>
  <data key="d2">Students will work in teams of 3 or 4 to engage in a mini-research project.</data>
  <data key="d3">chunk-843558fd9ea1f2553bd06e6050b8334b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1774749493</data>
  <data key="d6"></data>
</node>
<node id="Course Homework Collaboration Policy">
  <data key="d0">Course Homework Collaboration Policy</data>
  <data key="d1">academicpolicy</data>
  <data key="d2">Homework assignments are individual; students should write their own code but are encouraged to discuss approaches and methods. Pair programming, sharing code, or working through specific problems in code together are inappropriate, and all help must be acknowledged.</data>
  <data key="d3">chunk-843558fd9ea1f2553bd06e6050b8334b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1774749493</data>
  <data key="d6"></data>
</node>
<node id="Course Regrade Policy">
  <data key="d0">Course Regrade Policy</data>
  <data key="d1">academicpolicy</data>
  <data key="d2">Students have seven days after receiving a graded assignment to request a regrade in writing, with the instructor reserving the right to regrade the entire assignment.</data>
  <data key="d3">chunk-843558fd9ea1f2553bd06e6050b8334b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1774749493</data>
  <data key="d6"></data>
</node>
<node id="Course Late Work Policy">
  <data key="d0">Course Late Work Policy</data>
  <data key="d1">academicpolicy</data>
  <data key="d2">This policy states that makeup work for an excused absence is not considered late work and is exempt from the late work policy, referencing Student Rule 7.</data>
  <data key="d3">chunk-843558fd9ea1f2553bd06e6050b8334b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1774749493</data>
  <data key="d6"></data>
</node>
<node id="Student Rule 7">
  <data key="d0">Student Rule 7</data>
  <data key="d1">academicpolicy</data>
  <data key="d2">Student Rule 7 is an academic policy related to excused absences and makeup work.</data>
  <data key="d3">chunk-843558fd9ea1f2553bd06e6050b8334b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1774749493</data>
  <data key="d6"></data>
</node>
<node id="Course Homework Late Day Policy">
  <data key="d0">Course Homework Late Day Policy</data>
  <data key="d1">academicpolicy</data>
  <data key="d2">Homeworks are due by 11:59 PM on the due date. Each student receives five total late days, with each late day being an indivisible 24-hour unit. After using all late days, late assignments will receive a grade of 0.</data>
  <data key="d3">chunk-843558fd9ea1f2553bd06e6050b8334b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1774749493</data>
  <data key="d6"></data>
</node>
