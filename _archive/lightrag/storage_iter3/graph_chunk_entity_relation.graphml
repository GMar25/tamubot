<node id="Homework">
  <data key="d0">Homework</data>
  <data key="d1">gradecomponent</data>
  <data key="d2">Homework contributes 30% to the overall course grade and consists of five programming assignments.</data>
  <data key="d3">chunk-843558fd9ea1f2553bd06e6050b8334b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1774749493</data>
  <data key="d6"></data>
</node>
