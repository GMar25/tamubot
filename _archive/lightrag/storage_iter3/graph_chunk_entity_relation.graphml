  <data key="d0">Graduate Classification (CSCE 670)</data>
  <data key="d1">academicpolicy</data>
  <data key="d2">Graduate classification is a prerequisite for CSCE 670.</data>
  <data key="d3">chunk-97b761a3d4ccc38fabdc762f72330b3b</data>
