<node id="CSCE 670">
  <data key="d0">CSCE 670</data>
  <data key="d1">course</data>
  <data key="d2">CSCE 670 is the official course for Information Storage and Retrieval, Section 600 (46627), offered in Spring 2026 at College Station, with 3 credit hours (3-0).</data>
  <data key="d3">chunk-97b761a3d4ccc38fabdc762f72330b3b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1774749492</data>
  <data key="d6"></data>
</node>
<node id="Information Storage and Retrieval (Topic)">
  <data key="d0">Information Storage and Retrieval (Topic)</data>
  <data key="d1">coursetopic</data>
  <data key="d2">This topic covers the representation, storage, and access to very large multimedia document collections, fundamental data structures and algorithms, and techniques to design and evaluate complete retrieval systems, including indexing, compressing, and querying large collections.</data>
  <data key="d3">chunk-97b761a3d4ccc38fabdc762f72330b3b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1774749492</data>
  <data key="d6"></data>
</node>
<node id="CSCE 670 Spring 2026 Semester">
  <data key="d0">CSCE 670 Spring 2026 Semester</data>
  <data key="d1">scheduleevent</data>
  <data key="d2">The CSCE 670 course is offered during the Spring 2026 semester, starting January 12, 2026, and ending May 05, 2026.</data>
  <data key="d3">chunk-97b761a3d4ccc38fabdc762f72330b3b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1774749492</data>
  <data key="d6"></data>
</node>
