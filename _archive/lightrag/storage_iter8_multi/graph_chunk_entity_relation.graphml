  <data key="d0">CSCE 638 Learning Outcome 2</data>
  <data key="d1">learningoutcome</data>
  <data key="d2">Upon completion of CSCE 638, learners will be aware of recent trends in natural language processing research.</data>
  <data key="d3">chunk-37f87f6f2271f3ad9792c3057abb0778</data>
