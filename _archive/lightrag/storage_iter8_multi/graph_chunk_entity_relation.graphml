<graph edgedefault="undirected"><node id="CSCE 670">
  <data key="d0">CSCE 670</data>
  <data key="d1">course</data>
  <data key="d2">CSCE 670 is a course titled "Information Storage and Retrieval" offered in Spring 2026, section 600 (46627), in College Station. It carries 3 credit hours.&lt;SEP&gt;The course for which the policies, assignments, and textbooks are defined.&lt;SEP&gt;Represents the course to which these academic integrity policies apply.</data>
  <data key="d3">chunk-467fa41688e2d0b08f251e4c3b54fe08&lt;SEP&gt;chunk-93e94a289ffdcce48a1093462f9c1272&lt;SEP&gt;chunk-5dcf5ddfe952406b9bf6b1453f775403</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1774753301</data>
  <data key="d6" />
</node>
