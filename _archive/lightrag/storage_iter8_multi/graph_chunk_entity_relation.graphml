<node id="CSCE 638 Learning Outcome 1">
  <data key="d0">CSCE 638 Learning Outcome 1</data>
  <data key="d1">learningoutcome</data>
  <data key="d2">Upon completion of CSCE 638, learners will be able to identify and explain the key concepts and models for natural language processing.</data>
