<node id="Excused Absence">
  <data key="d0">Excused Absence</data>
  <data key="d1">academicpolicy</data>
  <data key="d2">An authorized reason for missing an exam, which may permit a student to take a makeup exam, provided documentation is supplied.&lt;SEP&gt;An excused absence is a university-defined condition that exempts makeup work from being subject to the late work policy.</data>
  <data key="d3">chunk-daa849f6a630caef4a2ea4121e93715e&lt;SEP&gt;chunk-aa73fee78ff788a909465d0d4489187a</data>
  <data key="d4">unknown_source</data>
