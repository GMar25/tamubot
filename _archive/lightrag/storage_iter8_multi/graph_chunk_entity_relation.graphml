  <data key="d1">document</data>
  <data key="d2">A document for this course that may contain assignment deadlines.&lt;SEP&gt;The Syllabus is a course document that may contain assignment deadlines, but Gradescope takes precedence for official deadlines.</data>
  <data key="d3">chunk-aa73fee78ff788a909465d0d4489187a&lt;SEP&gt;chunk-12f7de51d4f4e2342bdef5b2b88af321</data>
