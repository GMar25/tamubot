  <data key="d0">Yu Zhang</data>
  <data key="d1">instructor</data>
  <data key="d2">Yu Zhang is the instructor for CSCE 670. Yu Zhang's email is yuzhang@tamu.edu, office location is PETR 222, and phone number is (217) 954-3457.</data>
